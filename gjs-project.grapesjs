xt","name":"Badge Text","classes":["badge-text"],"components":[{"type":"textnode","content":"Nobel de Física (1921)"}]}]},{"tagName":"span","name":"Badge Item","classes":["badge-item"],"components":[{"type":"image","name":"Badge Icon","resizable":{"ratioDefault":1},"classes":["badge-icon"],"attributes":{"src":"https://api.iconify.design/lucide-atom.svg?color=%23e5e7eb","alt":"Ícono átomo"}},{"tagName":"span","type":"text","name":"Badge Text","classes":["badge-text"],"components":[{"type":"textnode","content":"Relatividad especial y general"}]}]}]}]},{"tagName":"figure","name":"Hero Figure","classes":["gjs-t-border","hero-figure"],"attributes":{"id":"ip7h486"},"components":[{"type":"image","name":"Hero Image","resizable":{"ratioDefault":1},"classes":["hero-image"],"attributes":{"src":"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRho-Z6McYaQV7eb-REcrYzWCVlxsGJTkLhIw&s","alt":"Retrato de Albert Einstein","id":"ici8gue"}},{"tagName":"figcaption","type":"text","name":"Hero Figcaption","classes":["hero-figcaption"],"components":[{"type":"textnode","content":"Retrato representativo de Albert Einstein, imagen de referencia."}]}]}]},{"tagName":"section","name":"Highlighted Contribution Section","classes":["highlighted-contribution-section"],"attributes":{"id":"isyj0j4"},"components":[{"name":"Contribution Card","classes":["gjs-t-border","contribution-card"],"components":[{"name":"Contribution Header","classes":["contribution-header"],"components":[{"type":"image","name":"Contribution Icon","resizable":{"ratioDefault":1},"classes":["contribution-icon"],"attributes":{"src":"https://api.iconify.design/lucide-flame.svg?color=%23a78bfa","alt":"Ícono aporte"}},{"tagName":"h2","type":"heading","name":"Contribution Title","classes":["gjs-t-h2"],"components":[{"type":"textnode","content":"Mayor aporte: Teoría de la relatividad y E=mc²"}]}]},{"tagName":"p","type":"text","name":"Contribution Text","classes":["contribution-text"],"components":[{"type":"textnode","content":"\n            La relatividad especial (1905) y la relatividad general (1915) redefinieron el espacio y el tiempo como entidades entrelazadas, introduciendo el concepto de espaciotiempo y la idea de que la gravedad es una manifestación de la curvatura del mismo.\n          "}]},{"name":"Contribution Details","classes":["contribution-details"],"components":[{"name":"Contribution Detail","classes":["contribution-detail"],"components":[{"tagName":"span","type":"text","name":"Contribution Label","classes":["contribution-label"],"components":[{"type":"textnode","content":"Fórmula icónica"}]},{"name":"Contribution Formula","classes":["contribution-formula"],"components":[{"type":"image","name":"Formula Icon","resizable":{"ratioDefault":1},"classes":["formula-icon"],"attributes":{"src":"https://api.iconify.design/lucide-equal.svg?color=%23e5e7eb","alt":"Ícono igual"}},{"tagName":"span","type":"text","name":"Formula Text","classes":["formula-text"],"components":[{"type":"textnode","content":"E = m c²"}]}]}]},{"name":"Contribution Detail","classes":["contribution-detail"],"components":[{"tagName":"span","type":"text","name":"Contribution Label","classes":["contribution-label"],"components":[{"type":"textnode","content":"Implicaciones clave"}]},{"tagName":"ul","name":"Contribution List","classes":["contribution-list"],"components":[{"tagName":"li","type":"text","name":"Contribution Item","classes":["contribution-item"],"components":[{"type":"textnode","content":"Equivalencia masa-energía"}]},{"tagName":"li","type":"text","name":"Contribution Item","classes":["contribution-item"],"components":[{"type":"textnode","content":"Dilación temporal"}]},{"tagName":"li","type":"text","name":"Contribution Item","classes":["contribution-item"],"components":[{"type":"textnode","content":"Contracción de longitud"}]},{"tagName":"li","type":"text","name":"Contribution Item","classes":["contribution-item"],"components":[{"type":"textnode","content":"Curvatura gravitacional"}]}]}]}]}]},{"tagName":"aside","name":"Quick Facts Sidebar","classes":["gjs-t-border","quick-facts-sidebar"],"attributes":{"id":"iuj0h2y"},"components":[{"name":"Quick Facts Header","classes":["quick-facts-header"],"components":[{"type":"image","name":"Quick Facts Icon","resizable":{"ratioDefault":1},"classes":["quick-facts-icon"],"attributes":{"src":"https://api.iconify.design/lucide-info.svg?color=%23e5e7eb","alt":"Ícono información"}},{"tagName":"h3","type":"heading","name":"Quick Facts Title","classes":["quick-facts-title"],"components":[{"type":"textnode","content":"Datos rápidos"}]}]},{"tagName":"ul","name":"Quick Facts List","classes":["quick-facts-list"],"components":[{"tagName":"li","name":"Quick Fact Item","classes":["quick-fact-item"],"components":[{"type":"image","name":"Quick Fact Icon","resizable":{"ratioDefault":1},"classes":["quick-fact-icon"],"attributes":{"src":"https://api.iconify.design/lucide-calendar.svg?color=%2394a3b8","alt":"Ícono calendario"}},{"tagName":"span","type":"text","name":"Quick Fact Text","classes":["quick-fact-text"],"components":[{"type":"textnode","content":"Nació en Ulm, Alemania (1879) • Falleció en Princeton, EE. UU. (1955)"}]}]},{"tagName":"li","name":"Quick Fact Item","classes":["quick-fact-item"],"components":[{"type":"image","name":"Quick Fact Icon","resizable":{"ratioDefault":1},"classes":["quick-fact-icon"],"attributes":{"src":"https://api.iconify.design/lucide-flask-conical.svg?color=%2394a3b8","alt":"Ícono frasco"}},{"tagName":"span","type":"text","name":"Quick Fact Text","classes":["quick-fact-text"],"components":[{"type":"textnode","content":"Campos: física teórica, cosmología, mecánica cuántica"}]}]},{"tagName":"li","name":"Quick Fact Item","classes":["quick-fact-item"],"components":[{"type":"image","name":"Quick Fact Icon","resizable":{"ratioDefault":1},"classes":["quick-fact-icon"],"attributes":{"src":"https://api.iconify.design/lucide-award.svg?color=%2394a3b8","alt":"Ícono premio"}},{"tagName":"span","type":"text","name":"Quick Fact Text","classes":["quick-fact-text"],"components":[{"type":"textnode","content":"Nobel por el efecto fotoeléctrico (1921)"}]}]}]},{"name":"Quick Facts Footer","classes":["quick-facts-footer"]}]}]},{"tagName":"section","name":"Biography Summary Section","classes":["gjs-t-border","biography-summary-section"],"components":[{"name":"Summary Header","classes":["summary-header"],"components":[{"type":"image","name":"Summary Icon","resizable":{"ratioDefault":1},"classes":["summary-icon"],"attributes":{"src":"https://api.iconify.design/lucide-user.svg?color=%23e5e7eb","alt":"Ícono usuario"}},{"tagName":"h2","type":"heading","name":"Summary Title","classes":["gjs-t-h2"],"components":[{"type":"textnode","content":"Resumen de su vida"}]}]},{"name":"Summary Content","classes":["summary-content"],"components":[{"tagName":"p","type":"text","name":"Summary Paragraph","components":[{"type":"textnode","content":"Albert Einstein fue un físico teórico nacido en Alemania (1879–1955). Revolucionó la física con sus teorías de relatividad especial y general, cambiando la forma en que entendemos el espacio, el tiempo, la energía y la gravedad."}]},{"tagName":"p","type":"text","name":"Summary Paragraph","components":[{"type":"textnode","content":"Recibió el Premio Nobel de Física por su explicación del efecto fotoeléctrico, piedra angular para el desarrollo de la mecánica cuántica y la tecnología de semiconductores. Además, realizó contribuciones importantes al estudio del movimiento browniano, la naturaleza de la luz, la estadística cuántica y la cosmología."}]},{"tagName":"p","type":"text","name":"Summary Paragraph","components":[{"type":"textnode","content":"Su trabajo trascendió la física, influyendo en la filosofía de la ciencia y en la cultura popular, convirtiéndose en uno de los científicos más reconocibles del siglo XX. Fue también una voz activa en temas sociales y políticos, defendiendo el pacifismo y la cooperación internacional."}]}]}]},{"tagName":"section","name":"Top Works Section","classes":["top-works-section"],"components":[{"name":"Top Works Card","classes":["gjs-t-border","top-works-card"],"components":[{"name":"Top Works Header","classes":["top-works-header"],"components":[{"type":"image","name":"Top Works Icon","resizable":{"ratioDefault":1},"classes":["top-works-icon"],"attributes":{"src":"https://api.iconify.design/lucide-list-ordered.svg?color=%23e5e7eb","alt":"Ícono lista"}},{"tagName":"h2","type":"heading","name":"Top Works Title","classes":["gjs-t-h2"],"components":[{"type":"textnode","content":"Top 5 trabajos adicionales"}]}]},{"tagName":"ol","name":"Top Works List","classes":["top-works-list"],"components":[{"tagName":"li","name":"Top Work Item","classes":["top-work-item"],"components":[{"tagName":"span","type":"text","name":"Top Work Index","classes":["top-work-index"],"components":[{"type":"textnode","content":"1"}]},{"name":"Top Work Content","classes":["top-work-content"],"components":[{"tagName":"h3","type":"heading","name":"Top Work Title","classes":["top-work-title"],"components":[{"type":"textnode","content":"Teoría de la relatividad especial (1905)"}]},{"tagName":"p","type":"text","name":"Top Work Description","classes":["top-work-description"],"components":[{"type":"textnode","content":"Postula que las leyes de la física son iguales en todos los marcos inerciales y que la velocidad de la luz es constante, introduciendo la dilación temporal y la contracción de longitud."}]}]}]},{"tagName":"li","name":"Top Work Item","classes":["top-work-item"],"components":[{"tagName":"span","type":"text","name":"Top Work Index","classes":["top-work-index"],"components":[{"type":"textnode","content":"2"}]},{"name":"Top Work Content","classes":["top-work-content"],"components":[{"tagName":"h3","type":"heading","name":"Top Work Title","classes":["top-work-title"],"components":[{"type":"textnode","content":"Teoría de la relatividad general (1915)"}]},{"tagName":"p","type":"text","name":"Top Work Description","classes":["top-work-description"],"components":[{"type":"textnode","content":"Describe la gravedad como curvatura del espaciotiempo causada por la masa y la energía, prediciendo fenómenos como el desplazamiento gravitacional al rojo y las lentes gravitacionales."}]}]}]},{"tagName":"li","name":"Top Work Item","classes":["top-work-item"],"components":[{"tagName":"span","type":"text","name":"Top Work Index","classes":["top-work-index"],"components":[{"type":"textnode","content":"3"}]},{"name":"Top Work Content","classes":["top-work-content"],"components":[{"tagName":"h3","type":"heading","name":"Top Work Title","classes":["top-work-title"],"components":[{"type":"textnode","content":"Efecto fotoeléctrico (1905)"}]},{"tagName":"p","type":"text","name":"Top Work Description","classes":["top-work-description"],"components":[{"type":"textnode","content":"Explicó que la luz puede comportarse como partículas (fotones), sentando bases para la teoría cuántica y tecnologías como celdas solares y sensores electrónicos."}]}]}]},{"tagName":"li","name":"Top Work Item","classes":["top-work-item"],"components":[{"tagName":"span","type":"text","name":"Top Work Index","classes":["top-work-index"],"components":[{"type":"textnode","content":"4"}]},{"name":"Top Work Content","classes":["top-work-content"],"components":[{"tagName":"h3","type":"heading","name":"Top Work Title","classes":["top-work-title"],"components":[{"type":"textnode","content":"Movimiento browniano (1905)"}]},{"tagName":"p","type":"text","name":"Top Work Description","classes":["top-work-description"],"components":[{"type":"textnode","content":"Demostró la existencia de átomos y moléculas mediante el análisis del movimiento aleatorio de partículas en un fluido, consolidando la teoría cinética."}]}]}]},{"tagName":"li","name":"Top Work Item","classes":["top-work-item"],"components":[{"tagName":"span","type":"text","name":"Top Work Index","classes":["top-work-index"],"components":[{"type":"textnode","content":"5"}]},{"name":"Top Work Content","classes":["top-work-content"],"components":[{"tagName":"h3","type":"heading","name":"Top Work Title","classes":["top-work-title"],"components":[{"type":"textnode","content":"Estadística de Bose–Einstein (1924–25)"}]},{"tagName":"p","type":"text","name":"Top Work Description","classes":["top-work-description"],"components":[{"type":"textnode","content":"Desarrolló, junto con S. N. Bose, la estadística para bosones y predijo la condensación de Bose–Einstein, fenómeno clave en física de materia ultrafría."}]}]}]}]}]},{"name":"Further Reading Card","classes":["gjs-t-border","further-reading-card"],"attributes":{"id":"im85wzz"},"components":[{"name":"Further Reading Header","classes":["further-reading-header"],"components":[{"type":"image","name":"Further Reading Icon","resizable":{"ratioDefault":1},"classes":["further-reading-icon"],"attributes":{"src":"https://api.iconify.design/lucide-book.svg?color=%23e5e7eb","alt":"Ícono libro"}},{"tagName":"h3","type":"heading","name":"Further Reading Title","classes":["further-reading-title"],"components":[{"type":"textnode","content":"Lecturas y vínculos"}]}]},{"tagName":"ul","name":"Further Reading List","classes":["further-reading-list"],"components":[{"tagName":"li","name":"Further Reading Item","classes":["further-reading-item"],"components":[{"type":"image","name":"Further Reading Item Icon","resizable":{"ratioDefault":1},"classes":["further-reading-item-icon"],"attributes":{"src":"https://api.iconify.design/lucide-link.svg?color=%23a78bfa","alt":"Ícono enlace"}},{"type":"link","name":"Further Reading Link","classes":["gjs-t-link","further-reading-link"],"attributes":{"href":"page://E2BgFcif1JRLHRbu"},"components":[{"type":"textnode","content":"Volver al diseño en grid de tarjetas"}]}]},{"tagName":"li","name":"Further Reading Item","classes":["further-reading-item"],"components":[{"type":"image","name":"Further Reading Item Icon","resizable":{"ratioDefault":1},"classes":["further-reading-item-icon"],"attributes":{"src":"https:/
-h2","subttulo-principal"],"components":[{"type":"textnode","content":"Matemático, físico y astrónomo inglés (1643–1727). Fundador de la física clásica; formuló las leyes del movimiento y la gravitación universal. Contribuyó al cálculo, óptica y mecánica celeste."}]},{"name":"Acciones Hero","classes":["acciones-hero"],"components":[{"type":"link","name":"Botón Principal","editable":false,"classes":["gjs-t-button","botn-principal"],"attributes":{"href":"#mayor-aporte","id":"i3rq7kx"},"components":[{"tagName":"span","type":"text","name":"Texto Botón","components":[{"type":"textnode","content":"Ver mayor aporte"}]}]},{"type":"link","name":"Enlace Secundario","editable":false,"classes":["enlace-secundario"],"attributes":{"href":"#trabajos"},"components":[{"type":"image","name":"Icono Lista","resizable":{"ratioDefault":1},"classes":["icono-lista"],"attributes":{"src":"https://api.iconify.design/lucide-list-ordered.svg?color=%23a78bfa","alt":"Icono Lista","id":"i8h1lkh"}},{"tagName":"span","type":"text","name":"Texto Enlace","attributes":{"id":"iswwhn8","__nc":""},"components":[{"type":"textnode","content":"Top 5 trabajos"}]}]}]}]},{"name":"Contenedor Imagen","classes":["contenedor-imagen"],"components":[{"tagName":"figure","name":"Figura Retrato","classes":["gjs-t-border","figura-retrato"],"components":[{"type":"image","name":"Imagen Retrato","resizable":{"ratioDefault":1},"classes":["imagen-retrato"],"attributes":{"src":"https://okdiario.com/img/2021/02/22/isaac-newton-2.jpg","alt":"Retrato de Isaac Newton","id":"itb7egs"}}]}]}]},{"tagName":"section","name":"Sección Mayor Aporte","classes":["seccin-mayor-aporte"],"attributes":{"id":"mayor-aporte-3"},"components":[{"name":"Tarjeta Mayor Aporte","classes":["gjs-t-border","tarjeta-mayor-aporte"],"components":[{"name":"Contenido Mayor Aporte","classes":["contenido-mayor-aporte"],"components":[{"name":"Icono Aporte","classes":["icono-aporte"],"components":[{"name":"Contenedor Icono","classes":["contenedor-icono"],"components":[{"type":"image","name":"SVG Icono Física","resizable":{"ratioDefault":1},"classes":["svg-icono-fsica"],"attributes":{"src":"https://api.iconify.design/lucide-atom.svg?color=%23a78bfa","alt":"Icono Física"}}]}]},{"name":"Texto Aporte","classes":["texto-aporte"],"components":[{"tagName":"h2","type":"heading","name":"Título Aporte","classes":["gjs-t-h2","ttulo-aporte"],"components":[{"type":"textnode","content":"Mayor aporte"}]},{"tagName":"p","type":"text","name":"Descripción Aporte","classes":["descripcin-aporte"],"components":[{"type":"textnode","content":"Leyes del movimiento y la gravitación universal. Sus tres leyes del movimiento describen la dinámica de los cuerpos, mientras que la ley de la gravitación universal explica la interacción gravitatoria entre masas. Juntas, constituyen el núcleo de la física clásica y fundamentan la mecánica celeste."}]},{"name":"Destacados Aporte","classes":["destacados-aporte"],"components":[{"name":"Item Destacado","classes":["item-destacado"],"components":[{"type":"image","name":"Icono Destacado","resizable":{"ratioDefault":1},"classes":["icono-destacado"],"attributes":{"src":"https://api.iconify.design/lucide-arrow-right.svg?color=%237dd3fc","alt":"Icono Ley 1"}},{"tagName":"span","type":"text","name":"Texto Destacado","classes":["texto-destacado"],"components":[{"type":"textnode","content":"Ley de Inercia"}]}]},{"name":"Item Destacado","classes":["item-destacado"],"components":[{"type":"image","name":"Icono Destacado","resizable":{"ratioDefault":1},"classes":["icono-destacado"],"attributes":{"src":"https://api.iconify.design/lucide-git-commit.svg?color=%237dd3fc","alt":"Icono Ley 2"}},{"tagName":"span","type":"text","name":"Texto Destacado","classes":["texto-destacado"],"components":[{"type":"textnode","content":"Relación Fuerza–Aceleración"}]}]},{"name":"Item Destacado","classes":["item-destacado"],"components":[{"type":"image","name":"Icono Destacado","resizable":{"ratioDefault":1},"classes":["icono-destacado"],"attributes":{"src":"https://api.iconify.design/lucide-refresh-ccw.svg?color=%237dd3fc","alt":"Icono Ley 3"}},{"tagName":"span","type":"text","name":"Texto Destacado","classes":["texto-destacado"],"components":[{"type":"textnode","content":"Acción y reacción"}]}]}]}]}]},{"name":"Cita Aporte","classes":["cita-aporte"],"components":[{"tagName":"blockquote","name":"Cita Destacada","classes":["cita-destacada"],"components":[{"type":"image","name":"Icono Cita","resizable":{"ratioDefault":1},"classes":["icono-cita"],"attributes":{"src":"https://api.iconify.design/lucide-quote.svg?color=%2394a3b8","alt":"Icono Cita"}},{"tagName":"p","type":"text","name":"Texto Cita","components":[{"type":"textnode","content":"Si he visto más lejos, es porque estoy sentado sobre los hombros de gigantes."}]}]}]}]}]},{"tagName":"section","name":"Sección Resumen Vida","classes":["seccin-resumen-vida"],"components":[{"name":"Grid Resumen","classes":["grid-resumen"],"components":[{"name":"Tarjeta Resumen","classes":["gjs-t-border","tarjeta-resumen"],"components":[{"name":"Encabezado Resumen","classes":["encabezado-resumen"],"components":[{"type":"image","name":"Icono Resumen","resizable":{"ratioDefault":1},"classes":["icono-resumen"],"attributes":{"src":"https://api.iconify.design/lucide-book-open.svg?color=%23a78bfa","alt":"Icono Libro"}},{"tagName":"h2","type":"heading","name":"Título Resumen","classes":["gjs-t-h2","ttulo-resumen"],"components":[{"type":"textnode","content":"Resumen de su vida"}]}]},{"name":"Contenido Resumen","classes":["contenido-resumen"],"components":[{"tagName":"p","type":"text","name":"Párrafo Resumen","components":[{"type":"textnode","content":"Isaac Newton nació en 1643 en Woolsthorpe, Inglaterra, y se convirtió en uno de los científicos más influyentes de la historia. Estudió en el Trinity College de la Universidad de Cambridge, donde desarrolló gran parte de su trabajo fundamental en matemáticas, física y astronomía."}]},{"tagName":"p","type":"text","name":"Párrafo Resumen","components":[{"type":"textnode","content":"Formuló las leyes del movimiento, que describen cómo cambian la velocidad y la dirección de los cuerpos bajo la influencia de fuerzas, y estableció la ley de la gravitación universal, que cuantifica la atracción entre todas las masas. Estos avances cimentaron la física clásica y explicaron con precisión el movimiento de los planetas."}]},{"tagName":"p","type":"text","name":"Párrafo Resumen","components":[{"type":"textnode","content":"En matemáticas, contribuyó decisivamente al desarrollo del cálculo infinitesimal. En óptica, estudió la naturaleza de la luz y construyó el primer telescopio reflector de uso práctico. Su obra más influyente, Philosophiæ Naturalis Principia Mathematica, sigue siendo una referencia esencial en la historia de la ciencia."}]}]}]},{"tagName":"aside","name":"Tarjeta Datos Clave","classes":["gjs-t-border","tarjeta-datos-clave"],"components":[{"name":"Encabezado Datos","classes":["encabezado-datos"],"components":[{"type":"image","name":"Icono Info","resizable":{"ratioDefault":1},"classes":["icono-info"],"attributes":{"src":"https://api.iconify.design/lucide-info.svg?color=%237dd3fc","alt":"Icono Info"}},{"tagName":"h3","type":"heading","name":"Título Datos","classes":["ttulo-datos"],"components":[{"type":"textnode","content":"Datos clave"}]}]},{"tagName":"ul","name":"Lista Datos","classes":["lista-datos"],"components":[{"tagName":"li","name":"Item Datos","classes":["item-datos"],"components":[{"type":"image","name":"Icono Fecha","resizable":{"ratioDefault":1},"classes":["icono-fecha"],"attributes":{"src":"https://api.iconify.design/lucide-calendar.svg?color=%2394a3b8","alt":"Icono Fecha"}},{"tagName":"span","type":"text","name":"Texto Datos","components":[{"type":"textnode","content":"1643–1727"}]}]},{"tagName":"li","name":"Item Datos","classes":["item-datos"],"components":[{"type":"image","name":"Icono Lugar","resizable":{"ratioDefault":1},"classes":["icono-lugar"],"attributes":{"src":"https://api.iconify.design/lucide-map-pin.svg?color=%2394a3b8","alt":"Icono Lugar"}},{"tagName":"span","type":"text","name":"Texto Datos","components":[{"type":"textnode","content":"Woolsthorpe, Lincolnshire, Inglaterra"}]}]},{"tagName":"li","name":"Item Datos","classes":["item-datos"],"components":[{"type":"image","name":"Icono Telescopio","resizable":{"ratioDefault":1},"classes":["icono-telescopio"],"attributes":{"src":"https://api.iconify.design/lucide-telescope.svg?color=%2394a3b8","alt":"Icono Telescopio"}},{"tagName":"span","type":"text","name":"Texto Datos","components":[{"type":"textnode","content":"Telescopio reflector"}]}]},{"tagName":"li","name":"Item Datos","classes":["item-datos"],"components":[{"type":"image","name":"Icono Mérito","resizable":{"ratioDefault":1},"classes":["icono-mrito"],"attributes":{"src":"https://api.iconify.design/lucide-medal.svg?color=%2394a3b8","alt":"Icono Mérito"}},{"tagName":"span","type":"text","name":"Texto Datos","components":[{"type":"textnode","content":"Presidente de la Royal Society"}]}]}]},{"name":"Nota Datos","classes":["nota-datos"],"components":[{"tagName":"p","type":"text","name":"Texto Nota","classes":["texto-nota"],"components":[{"type":"textnode","content":"Su enfoque experimental y matemático consolidó un método para la comprensión del universo físico."}]}]}]}]}]},{"tagName":"section","name":"Sección Trabajos","classes":["seccin-trabajos"],"attributes":{"id":"trabajos-2"},"components":[{"name":"Encabezado Trabajos","classes":["encabezado-trabajos"],"components":[{"tagName":"h2","type":"heading","name":"Título Trabajos","classes":["gjs-t-h2","ttulo-trabajos"],"components":[{"type":"textnode","content":"Top 5 trabajos adicionales"}]},{"type":"link","name":"Enlace Lecturas","classes":["gjs-t-link","enlace-lecturas"],"attributes":{"href":"#lecturas"},"components":[{"type":"textnode","content":"Lecturas recomendadas"}]}]},{"tagName":"ul","name":"Lista Trabajos","classes":["lista-trabajos"],"components":[{"tagName":"li","name":"Item Trabajo","classes":["gjs-t-border","item-trabajo"],"components":[{"type":"image","name":"Icono Trabajo","resizable":{"ratioDefault":1},"classes":["icono-trabajo"],"attributes":{"src":"https://api.iconify.design/lucide-file-text.svg?color=%237dd3fc","alt":"Icono Documento"}},{"name":"Contenido Trabajo","components":[{"tagName":"h3","type":"heading","name":"Título Trabajo","classes":["ttulo-trabajo"],"components":[{"type":"textnode","content":"Principia Mathematica"}]},{"tagName":"p","type":"text","name":"Descripción Trabajo","classes":["descripcin-trabajo"],"components":[{"type":"textnode","content":"Obra fundamental que establece las bases matemáticas de la física clásica y la mecánica celeste."}]}]}]},{"tagName":"li","name":"Item Trabajo","classes":["gjs-t-border","item-trabajo"],"components":[{"type":"image","name":"Icono Trabajo","resizable":{"ratioDefault":1},"classes":["icono-trabajo"],"attributes":{"src":"https://api.iconify.design/lucide-activity.svg?color=%237dd3fc","alt":"Icono Movimiento"}},{"name":"Contenido Trabajo","components":[{"tagName":"h3","type":"heading","name":"Título Trabajo","classes":["ttulo-trabajo"],"components":[{"type":"textnode","content":"Leyes del movimiento"}]},{"tagName":"p","type":"text","name":"Descripción Trabajo","classes":["descripcin-trabajo"],"components":[{"type":"textnode","content":"Tres principios que explican la dinámica de los cuerpos bajo la acción de fuerzas."}]}]}]},{"tagName":"li","name":"Item Trabajo","classes":["gjs-t-border","item-trabajo"],"components":[{"type":"image","name":"Icono Trabajo","resizable":{"ratioDefault":1},"classes":["icono-trabajo"],"attributes":{"src":"https://api.iconify.design/lucide-orbit.svg?color=%237dd3fc","alt":"Icono Órbita"}},{"name":"Contenido Trabajo","components":[{"tagName":"h3","type":"heading","name":"Título Trabajo","classes":["ttulo-trabajo"],"components":[{"type":"textnode","content":"Ley de gravitación universal"}]},{"tagName":"p","type":"text","name":"Descripción Trabajo","classes":["descripcin-trabajo"],"components":[{"type":"textnode","content":"Relación matemática de la fuerza de atracción entre dos masas separadas por una distancia."}]}]}]},{"tagName":"li","name":"Item Trabajo","classes":["gjs-t-border","item-trabajo"],"components":[{"type":"image","name":"Icono Trabajo","resizable":{"ratioDefault":1},"classes":["icono-trabajo"],"attributes":{"src":"https://api.iconify.design/lucide-sun.svg?color=%237dd3fc","alt":"Icono Luz"}},{"name":"Contenido Trabajo","components":[{"tagName":"h3","type":"heading","name":"Título Trabajo","classes":["ttulo-trabajo"],"components":[{"type":"textnode","content":"Estudios sobre óptica y luz"}]},{"tagName":"p","type":"text","name":"Descripción Trabajo","classes":["descripcin-trabajo"],"components":[{"type":"textnode","content":"Investigaciones sobre la naturaleza de la luz, descomposición con prismas y teoría corpuscular."}]}]}]},{"tagName":"li","name":"Item Trabajo","classes":["gjs-t-border","item-trabajo"],"components":[{"type":"image","name":"Icono Trabajo","resizable":{"ratioDefault":1},"classes":["icono-trabajo"],"attributes":{"src":"https://api.iconify.design/lucide-calculator.svg?color=%237dd3fc","alt":"Icono Cálculo"}},{"name":"Contenido Trabajo","components":[{"tagName":"h3","type":"heading","name":"Título Trabajo","classes":["ttulo-trabajo"],"components":[{"type":"textnode","content":"Desarrollo del cálculo infinitesimal"}]},{"tagName":"p","type":"text","name":"Descripción Trabajo","classes":["descripcin-trabajo"],"components":[{"type":"textnode","content":"Formalización de métodos matemáticos para el estudio de variaciones y tasas de cambio."}]}]}]}]}]},{"tagName":"section","name":"Sección Lecturas","classes":["seccin-lecturas"],"attributes":{"id":"lecturas"},"components":[{"name":"Tarjeta Lecturas","classes":["gjs-t-border","tarjeta-lecturas"],"components":[{"name":"Encabezado Lecturas","classes":["encabezado-lecturas"],"components":[{"type":"image","name":"Icono Biblioteca","resizable":{
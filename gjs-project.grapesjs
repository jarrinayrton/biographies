Ver mayor aporte"}]}]},{"type":"link","editable":false,"classes":["secondary-cta"],"attributes":{"href":"#top-trabajos","id":"irnf7ej"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["cta2-icon"],"attributes":{"src":"https://api.iconify.design/lucide-list-ordered.svg?color=%23111827","alt":"Lista","id":"ihnwcqk"}},{"tagName":"span","type":"text","attributes":{"id":"ibkunhj"},"components":[{"type":"textnode","content":"Top 5 trabajos"}]}]}]},{"classes":["breadcrumbs"],"attributes":{"id":"ihcysaj"},"components":[{"type":"link","classes":["gjs-t-link","breadcrumb-link"],"attributes":{"href":"./index.html","id":"i4vi0xz"},"components":[{"type":"textnode","content":"Explorar científicos"}]},{"tagName":"span","type":"text","classes":["breadcrumb-divider"],"attributes":{"aria-hidden":"true","id":"i3gyycn"},"components":[{"type":"textnode","content":"/"}]},{"tagName":"span","type":"text","classes":["breadcrumb-current"],"attributes":{"id":"iii414j"},"components":[{"type":"textnode","content":"Mildred Dresselhaus"}]}]}]},{"classes":["hero-portrait-wrapper"],"attributes":{"id":"iw4trim"},"components":[{"tagName":"figure","classes":["gjs-t-border","portrait-figure"],"attributes":{"id":"i848t7t"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["portrait-image"],"attributes":{"src":"https://11defebrero.org/wp-content/uploads/2018/03/mildred-dresselhaus.jpg?w=685","alt":"Retrato de Mildred Dresselhaus","id":"i94z5ld"}}]}]}]}]},{"tagName":"section","classes":["aporte-section"],"attributes":{"id":"mayor-aporte-2"},"components":[{"classes":["aporte-container"],"attributes":{"id":"ikwvue9"},"components":[{"classes":["gjs-t-border","aporte-card"],"attributes":{"id":"i8zf3ae"},"components":[{"classes":["aporte-header"],"attributes":{"id":"i1qerg2"},"components":[{"classes":["aporte-icon-wrapper"],"attributes":{"id":"i9ca9rn"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["aporte-icon"],"attributes":{"src":"https://api.iconify.design/lucide-star.svg?color=%237c3aed","alt":"Mayor aporte","id":"ihoya5w"}}]},{"classes":["aporte-title-wrapper"],"attributes":{"id":"ivrx41a"},"components":[{"tagName":"h2","type":"heading","classes":["gjs-t-h2","aporte-title"],"attributes":{"id":"i59nmtj"},"components":[{"type":"textnode","content":"Mayor aporte"}]},{"tagName":"p","type":"text","classes":["aporte-subtitle"],"attributes":{"id":"i93k7jf"},"components":[{"type":"textnode","content":"Pionera en el estudio del carbono, nanotubos y nanociencia; conocida como “La Reina del Carbono”."}]}]}]},{"classes":["aporte-details-grid"],"attributes":{"id":"i5sh9bk"},"components":[{"classes":["aporte-detail"],"attributes":{"id":"i7uuh8f"},"components":[{"tagName":"h3","type":"heading","classes":["aporte-detail-title"],"attributes":{"id":"iqf3lrc"},"components":[{"type":"textnode","content":"Carbono en todas sus formas"}]},{"tagName":"p","type":"text","classes":["aporte-detail-text"],"attributes":{"id":"iu0zy3u"},"components":[{"type":"textnode","content":"Estudios fundamentales del grafito, grafeno incipiente y nanotubos de carbono, estableciendo bases para la electrónica y la ciencia de materiales a escala nano."}]}]},{"classes":["aporte-detail"],"attributes":{"id":"ifc7zq2"},"components":[{"tagName":"h3","type":"heading","classes":["aporte-detail-title"],"attributes":{"id":"iop3j3h"},"components":[{"type":"textnode","content":"Métodos y propiedades"}]},{"tagName":"p","type":"text","classes":["aporte-detail-text"],"attributes":{"id":"ifclydd"},"components":[{"type":"textnode","content":"Caracterización de propiedades electrónicas, vibracionales y térmicas en sistemas de baja dimensionalidad; espectroscopía Raman y transporte como herramientas clave."}]}]},{"classes":["aporte-detail"],"attributes":{"id":"ilbk5bo"},"components":[{"tagName":"h3","type":"heading","classes":["aporte-detail-title"],"attributes":{"id":"i6ms8rm"},"components":[{"type":"textnode","content":"Impacto transversal"}]},{"tagName":"p","type":"text","classes":["aporte-detail-text"],"attributes":{"id":"i49wmw8"},"components":[{"type":"textnode","content":"Impulso a aplicaciones en energía, termoeléctricos y dispositivos nano; puente entre investigación básica y tecnologías escalables."}]}]}]}]}]}]},{"tagName":"section","classes":["resumen-section"],"attributes":{"id":"ikpp1uq"},"components":[{"classes":["resumen-container"],"attributes":{"id":"i5vkk1e"},"components":[{"classes":["resumen-grid"],"attributes":{"id":"ij98bn7"},"components":[{"tagName":"article","classes":["resumen-article"],"attributes":{"id":"izcx49p"},"components":[{"classes":["resumen-prose"],"attributes":{"id":"i3prmmu"},"components":[{"tagName":"h2","type":"heading","classes":["gjs-t-h2","resumen-title"],"attributes":{"id":"intntcw"},"components":[{"type":"textnode","content":"Resumen de su vida"}]},{"classes":["resumen-text"],"attributes":{"id":"ierfbpd"},"components":[{"tagName":"p","type":"text","attributes":{"id":"i42b4xi"},"components":[{"type":"textnode","content":"Mildred S. Dresselhaus (1930–2017) fue una física y profesora del MIT que transformó la comprensión de los materiales basados en carbono. Su trabajo abarcó desde el grafito y estructuras de baja dimensionalidad hasta nanotubos de carbono y nanohilos semiconductores, contribuyendo a cimentar la nanociencia moderna."}]},{"tagName":"p","type":"text","attributes":{"id":"iwu7nk9"},"components":[{"type":"textnode","content":"Rompiendo barreras de género en STEM, dedicó parte de su carrera a abrir caminos para mujeres en la ciencia y la ingeniería. Fue presidenta de la American Physical Society (APS) y de la IEEE, y recibió múltiples reconocimientos, entre ellos la Medalla Nacional de la Ciencia y el Premio Kavli."}]},{"tagName":"p","type":"text","attributes":{"id":"ibj4mdj"},"components":[{"type":"textnode","content":"Además de sus aportes en carbono, trabajó en superconductividad, propiedades del estado sólido y energía, conectando investigación fundamental con aplicaciones tecnológicas. Su enfoque meticuloso y visión interdisciplinaria siguen inspirando a generaciones de investigadores."}]}]},{"classes":["resumen-highlights"],"attributes":{"id":"icraphg"},"components":[{"classes":["highlights-card"],"attributes":{"id":"i60vjhe"},"components":[{"tagName":"h3","type":"heading","classes":["highlights-title"],"attributes":{"id":"ixiethq"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["highlights-icon"],"attributes":{"src":"https://api.iconify.design/lucide-award.svg?color=%23111827","alt":"Premios","id":"iave4u9"}},{"type":"textnode","content":"\n                  Premios y liderazgo\n                "}]},{"tagName":"ul","classes":["highlights-list"],"attributes":{"id":"iohvktc"},"components":[{"tagName":"li","classes":["highlights-item"],"attributes":{"id":"i58f3y7"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["highlights-item-icon"],"attributes":{"src":"https://api.iconify.design/lucide-badge-check.svg?color=%237c3aed","alt":"Reconocimiento","id":"i42nz2w"}},{"type":"textnode","content":"\n                    Presidenta de APS e IEEE\n                  "}]},{"tagName":"li","classes":["highlights-item"],"attributes":{"id":"itp3g0m"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["highlights-item-icon"],"attributes":{"src":"https://api.iconify.design/lucide-badge-check.svg?color=%237c3aed","alt":"Reconocimiento","id":"i32007s"}},{"type":"textnode","content":"\n                    Medalla Nacional de la Ciencia\n                  "}]},{"tagName":"li","classes":["highlights-item"],"attributes":{"id":"i064y5j"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["highlights-item-icon"],"attributes":{"src":"https://api.iconify.design/lucide-badge-check.svg?color=%237c3aed","alt":"Reconocimiento","id":"ib4eaik"}},{"type":"textnode","content":"\n                    Premio Kavli de Nanociencia\n                  "}]},{"tagName":"li","cl
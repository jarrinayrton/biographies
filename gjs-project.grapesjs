design/lucide-flask-conical.svg?color=%23a78bfa","alt":"Ciencia"}},{"tagName":"h3","type":"heading","classes":["card-title"],"components":[{"type":"textnode","content":"Nikola Tesla"}]}]},{"tagName":"span","classes":["card-tag"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["card-tag-icon"],"attributes":{"src":"https://api.iconify.design/lucide-zap.svg?color=%23e5e7eb","alt":"Electromagnetismo"}},{"type":"textnode","content":"\n        Electromagnetismo\n      "}]}]},{"classes":["card-highlight"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["highlight-icon"],"attributes":{"src":"https://api.iconify.design/lucide-award.svg?color=%23e5e7eb","alt":"Mayor aporte"}},{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Mayor aporte:"}]},{"tagName":"span","type":"text","classes":["highlight-value"],"components":[{"type":"textnode","content":"Desarrollo del sistema de corriente alterna (AC) y numerosas innovaciones en electromagnetismo."}]}]},{"tagName":"p","type":"text","classes":["card-summary"],"components":[{"type":"textnode","content":"Nikola Tesla (1856–1943) fue un inventor, ingeniero eléctrico y físico nacido en Croacia. Migró a Estados Unidos en 1884, trabajó para Thomas Edison antes de establecer sus propios laboratorios. Revolucionó la ingeniería eléctrica con la corriente alterna, motores AC y la bobina de Tesla. Investigó ondas electromagnéticas, radio y transmisión inalámbrica. Murió en relativo olvido, hoy es celebrado como uno de los inventores más brillantes."}]},{"classes":["card-works"],"components":[{"classes":["works-header"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["works-icon"],"attributes":{"src":"https://api.iconify.design/lucide-list-ordered.svg?color=%23e5e7eb","alt":"Top trabajos"}},{"tagName":"span","type":"text","classes":["works-title"],"components":[{"type":"textnode","content":"Top 5 Contribuciones y Logros en la Ciencia"}]}]},{"tagNa
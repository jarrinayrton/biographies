xZHFQIEbU5RR"},{"name":"Biografía Nikola Tesla","frames":[{"component":{"type":"wrapper","name":"Body","classes":["gjs-t-body","body"],"components":[{"tagName":"main","name":"Main Container","classes":["main-container"],"components":[{"tagName":"section","name":"Header Section","classes":["header-section"],"attributes":{"id":"ips04gb"},"components":[{"name":"Header Text Block","classes":["header-text-block"],"components":[{"type":"heading","name":"Title","classes":["gjs-t-h1","title"],"components":[{"type":"textnode","content":"Nikola Tesla"}]},{"tagName":"p","type":"text","name":"Subtitle","classes":["subtitle"],"components":[{"type":"textnode","content":"Inventor visionario, ingeniero eléctrico y pionero del electromagnetismo"}]},{"name":"Header Actions","classes":["header-actions"],"components":[{"type":"link","name":"Primary Button","classes":["gjs-t-button","primary-button"],"attributes":{"href":"page://E2BgFcif1JRLHRbu"},"components":[{"type":"image","name":"Icon Home","resizable":{"ratioDefault":1},"classes":["icon-home"],"attributes":{"src":"https://api.iconify.design/lucide-home.svg?color=%23111827","alt":"Inicio"}},{"type":"textnode","content":"\n            Volver a la página principal\n          "}]},{"type":"link","name":"Secondary Link","classes":["gjs-t-link","secondary-link"],"attributes":{"href":"page://E2BgFcif1JRLHRbu"},"components":[{"type":"image","name":"Icon Grid","resizable":{"ratioDefault":1},"classes":["icon-grid"],"attributes":{"src":"https://api.iconify.design/lucide-grid-2x2.svg?color=%23a78bfa","alt":"Científicos"}},{"type":"textnode","content":"\n            Ver todos los científicos\n          "}]}]}]},{"tagName":"figure","name":"Figure Container","classes":["gjs-t-border","figure-container"],"components":[{"type":"image","name":"Figure Image","resizable":{"ratioDefault":1},"classes":["figure-image"],"attributes":{"src":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/87/Teslathinker.jpg/250px-Teslathinker.jpg","alt":"Figura 4: Nikola Tesla","id":"ikr7gmh"}}]}]},{"tagName":"section","name":"Highlight and Summary Section","classes":["highlight-and-summary-section"],"components":[{"name":"Highlight Card","classes":["gjs-t-border","highlight-card"],"attributes":{"id":"ibc1m6d"},"components":[{"name":"Highlight Header","classes":["highlight-header"],"components":[{"type":"image","name":"Icon Bolt","resizable":{"ratioDefault":1},"classes":["icon-bolt"],"attributes":{"src":"https://api.iconify.design/lucide-bolt.svg?color=%23a78bfa","alt":"Aporte"}},{"tagName":"h2","type":"heading","name":"Highlight Title","classes":["gjs-t-h2","highlight-title"],"components":[{"type":"textnode","content":"Mayor aporte"}]}]},{"tagName":"p","type":"text","name":"Highlight Text","classes":["highlight-text"],"components":[{"type":"textnode","content":"\n          Desarrollo del sistema de corriente alterna (AC) y numerosas innovaciones en electromagnetismo.\n        "}]},{"name":"Highlight Badges","classes":["highlight-badges"],"components":[{"tagName":"span","name":"Badge","classes":["badge"],"components":[{"type":"image","name":"Icon Activity","resizable":{"ratioDefault":1},"classes":["icon-activity"],"attributes":{"src":"https://api.iconify.design/lucide-activity.svg?color=%23a78bfa","alt":"AC"}},{"type":"textnode","content":"\n            Corriente alterna (AC)\n          "}]},{"tagName":"span","name":"Badge","classes":["badge"],"components":[{"type":"image","name":"Icon Radio","resizable":{"ratioDefault":1},"classes":["icon-radio"],"attributes":{"src":"https://api.iconify.design/lucide-radio.svg?color=%23a78bfa","alt":"Radio"}},{"type":"textnode","content":"\n            Transmisión inalámbrica\n          "}]},{"tagName":"span","name":"Badge","classes":["badge"],"components":[{"type":"image","name":"Icon Cog","resizable":{"ratioDefault":1},"classes":["icon-cog"],"attributes":{"src":"https://api.iconify.design/lucide-cog.svg?color=%23a78bfa","alt":"Motor"}},{"type":"textnode","content":"\n            Motores de inducción\n          "}]}]}]},{"name":"Summary Card","classes":["gjs-t-border","summary-card"],"components":[{"name":"Summary Header","classes":["summary-header"],"components":[{"type":"image","name":"Icon Book","resizable":{"ratioDefault":1},"classes":["icon-book"],"attributes":{"src":"https://api.iconify.design/lucide-book-open.svg?color=%23a78bfa","alt":"Resumen"}},{"tagName":"h2","type":"heading","name":"Summary Title","classes":["gjs-t-h2","summary-title"],"components":[{"type":"textnode","content":"Resumen de su vida"}]}]},{"name":"Summary Text","classes":["summary-text"],"components":[{"tagName":"p","type":"text","name":"Summary Paragraph","components":[{"type":"textnode","content":"\n            Nikola Tesla (1856–1943) fue un inventor, ingeniero eléctrico y físico nacido en la actual Croacia. Migró a Estados Unidos en 1884, donde trabajó para Thomas Edison antes de establecer sus propios laboratorios e iniciar sus investigaciones independientes.\n          "}]},{"tagName":"p","type":"text","name":"Summary Paragraph","components":[{"type":"textnode","content":"\n            Tesla revolucionó el campo de la ingeniería eléctrica con el desarrollo de la corriente alterna, los motores AC y el transformador Tesla. También investigó ondas electromagnéticas, radio y transmisión inalámbrica de energía.\n          "}]},{"tagName":"p","type":"text","name":"Summary Paragraph","components":[{"type":"textnode","content":"\n            Aunque sus ideas fueron visionarias, muchas no fueron comprendidas en su tiempo, y murió en relativo olvido, aunque hoy es celebrado como uno de los inventores más brillantes de la historia.\n          "}]}]}]}]},{"tagName":"section","name":"Top Contributions Section","classes":["gjs-t-border","top-contributions-section"],"attributes":{"id":"i5zrbuu"},"components":[{"name":"Top Header","classes":["top-header"],"components":[{"type":"image","name":"Icon Trophy","resizable":{"ratioDefault":1},"classes":["icon-trophy"],"attributes":{"src":"https://api.iconify.design/lucide-trophy.svg?color=%23a78bfa","alt":"Top"}},{"tagName":"h2","type":"heading","name":"Top Title","classes":["gjs-t-h2","top-title"],"components":[{"type":"textnode","content":"Top 5 Contribuciones y Logros en la Ciencia"}]}]},{"tagName":"ol","name":"Top List","classes":["top-list"],"components":[{"tagName":"li","name":"Top Item","classes":["top-item"],"components":[{"tagName":"span","type":"text","name":"Top Index","classes":["top-index"],"components":[{"type":"textnode","content":"1"}]},{"name":"Top Content","classes":["top-content"],"components":[{"tagName":"p","type":"text","name":"Top Text","classes":["top-text"],"components":[{"type":"textnode","content":"Desarrollo del sistema de corriente alterna (AC)"}]}]}]},{"tagName":"li","name":"Top Item","classes":["top-item"],"components":[{"tagName":"span","type":"text","name":"Top Index","classes":["top-index"],"components":[{"type":"textnode","content":"2"}]},{"name":"Top Content","classes":["top-content"],"components":[{"tagName":"p","type":"text","name":"Top Text","classes":["top-text"],"components":[{"type":"textnode","content":"Invención de la bobina de Tesla"}]}]}]},{"tagName":"li","name":"Top Item","classes":["top-item"],"components":[{"tagName":"span","type":"text","name":"Top Index","classes":["top-index"],"components":[{"type":"textnode","content":"3"}]},{"name":"Top Content","classes":["top-content"],"components":[{"tagName":"p","type":"text","name":"Top Text","classes":["top-text"],"components":[{"type":"textnode","content":"Contribuciones a la radio y transmisión inalámbrica"}]}]}]},{"tagName":"li","name":"Top Item","classes":["top-item"],"components":[{"tagName":"span","type":"text","name":"Top Index","classes":["top-index"],"components":[{"type":"textnode","content":"4"}]},{"name":"Top Content","classes":["top-content"],"components":[{"tagName":"p","type":"text","name":"Top Text","classes":["top-text"],"components":[{"type":"textnode","content":"Motores y generadores de inducción"}]}]}]},{"tagName":"li","name":"Top Item","classes":["top-item"],"components":[{"tagName":"span","type":"text","name":"Top Index","classes":["top-index"],"components":[{"type":"textnode","content":"5"}]},{"name":"Top Content","classes":["top-content"],"components":[{"tagName":"p","type":"text","name":"Top Text","classes":["top-text"],"components":[{"type":"textnode","content":"Investigaciones en resonancia electromagnética"}]}]}]}]}]},{"tagName":"section","name":"Extended Section","classes":["extended-section"],"components":[{"tagName":"aside","name":"Quick Facts","classes":["gjs-t-border","quick-facts"],"components":[{"name":"Facts Header","classes":["facts-header"],"components":[{"type":"image","name":"Icon Info","resizable":{"ratioDefault":1},"classes":["icon-info"],"attributes":{"src":"https://api.iconify.design/lucide-info.svg?color=%23a78bfa","alt":"Datos"}},{"tagName":"h2","type":"heading","name":"Facts Title","classes":["gjs-t-h2","facts-title"],"components":[{"type":"textnode","content":"Datos clave"}]}]},{"tagName":"ul","name":"Facts List","classes":["facts-list"],"components":[{"tagName":"li","name":"Fact Item","classes":["fact-item"],"components":[{"type":"image","name":"Icon Calendar","resizable":{"ratioDefault":1},"classes":["icon-calendar"],"attributes":{"src":"https://api.iconify.design/lucide-calendar.svg?color=%2394a3b8","alt":"Fechas"}},{"type":"textnode","content":"\n            1856–1943\n          "}]},{"tagName":"li","name":"Fact Item","classes":["fact-item"],"components":[{"type":"image","name":"Icon Map","resizable":{"ratioDefault":1},"classes":["icon-map"],"attributes":{"src":"https://api.iconify.design/lucide-map-pin.svg?color=%2394a3b8","alt":"Origen"}},{"type":"textnode","content":"\n            Nacido en Smiljan (actual Croacia)\n          "}]},{"tagName":"li","name":"Fact Item","classes":["fact-item"],"components":[{"type":"image","name":"Icon Factory","resizable":{"ratioDefault":1},"classes":["icon-factory"],"attributes":{"src":"https://api.iconify.design/lucide-factory.svg?color=%2394a3b8","alt":"Trabajo"}},{"type":"textnode","content":"\n            Trabajó brevemente para Thomas Edison\n          "}]},{"tagName":"li","name":"Fact Item","classes":["fact-item"],"components":[{"type":"image","name":"Icon Zap","resizable":{"ratioDefault":1},"classes":["icon-zap"],"attributes":{"src":"https://api.iconify.design/lucide-zap.svg?color=%2394a3b8","alt":"AC"}},{"type":"textnode","content":"\n            Campeón del sistema de corriente alterna\n          "}]},{"tagName":"li","name":"Fact Item","classes":["fact-item"],"components":[{"type":"image","name":"Icon Waves","resizable":{"ratioDefault":1},"classes":["icon-waves"],"attributes":{"src":"https://api.iconify.design/lucide-waves.svg?color=%2394a3b8","alt":"Ondas"}},{"type":"textnode","content":"\n            Pionero de la transmisión inalámbrica\n          "}]}]}]},{"name":"Extended Bio","classes":["gjs-t-border","extended-bio"],"attributes":{"id":"iam13wg"},"components":[{"name":"Extended Header","classes":["extended-header"],"components":[{"type":"image","name":"Icon FileText","resizable":{"ratioDefault":1},"classes":["icon-filetext"],"attributes":{"src":"https://api.iconify.design/lucide-file-text.svg?color=%23a78bfa","alt":"Bio"}},{"tagName":"h2","type":"heading","name":"Extended Title","classes":["gjs-t-h2","extended-title"],"components":[{"type":"textnode","content":"Biografía extendida"}]}]},{"name":"Extended Text","classes":["extended-text"],"components":[{"tagName":"p","type":"text","name":"Extended Paragraph","components":[{"type":"textnode","content":"\n            Tras su llegada a Nueva York en 1884, Tesla fue contratado por la empresa de Thomas Edison. Pronto sus visiones y enfoque ingenieril chocaron con el marco de la corriente continua (DC) que dominaba la industria, motivándolo a crear sus propios laboratorios para desarrollar sistemas de corriente alterna (AC), que eventualmente se convertirían en el estándar global por su eficiencia y facilidad para la transmisión a largas distancias.\n          "}]},{"tagName":"p","type":"text","name":"Extended Paragraph","components":[{"type":"textnode","content":"\n            Su célebre bobina de Tesla sentó bases para la investigación de altas tensiones, resonancia y fenómenos de radiofrecuencia. A lo largo de su vida, Tesla obtuvo numerosas patentes, exploró redes de iluminación, motores de inducción y prototipos de transmisión de energía sin cables, anticipando tecnologías que se consolidarían décadas más tarde.\n          "}]},{"tagName":"p","type":"text","name":"Extended Paragraph","components":[{"type":"textnode","content":"\n            A pesar de sus contribuciones inmensas, el reconocimiento tardó en llegar. Falleció en 1943 en Nueva York, en relativo anonimato. Hoy, se lo considera uno de los inventores más influyentes y visionarios, con un legado que inspira la innovación contemporánea.\n          "}]}]},{"name":"Extended Media Grid","classes":["extended-media-grid"],"components":[{"name":"Media Card","classes":["gjs-t-border","media-card"],"components":[{"type":"image","name":"Media Image","resizable":{"ratioDefault":1},"classes":["media-image"],"attributes":{"loading":"lazy","src":"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTm3bzg2xyJHI-SPl7USiVgfmbF6v3eWs3Itw&s","alt":"Bobina de Tesla","id":"i3bnjk1"}},{"type":"text","name":"Media Caption","classes":["media-caption"],"components":[{"type":"textnode","content":"Bobina de Tesla: experimentos de alta tensión y resonancia"}]}]},{"name":"Media Card","classes":["gjs-t-border","media-card"],"components":[{"type":"image","name":"Media Image","resizable":{"ratioDefault":1},"classes":["media-image"],"attributes":{"loading":"lazy","src":"https://app.grapesjs.com/api/assets/random-image?query=%22AC%20power%20grid%22&w=560&h=320","alt":"Sistema de corriente alterna"}},{"type":"text","name":"Media Caption","classes":["media-caption"],"components":[{"type":"textnode","content":"Sistema AC: transmisión eficiente a larga distancia"}]}]}]}]}]},{"tagName":"section","name":"Footer Actions Section","classes":["gjs-t-border","footer-actions-section"],"components":[{"name":"Footer Left","classes":["footer-left"],"components":[{"type":"image","name":"Icon ArrowLeft","resizable":{"ratioDefault":1},"classes":["icon-arrowleft"],"attributes":{"src":"https://api.iconify.design/lucide-arrow-left.svg?color=%23a78bfa","alt":"Volver"}},{"type":"link","name":"Footer Link","classes":["gjs-t-link","footer-link"],"attributes":{"href":"page://E2BgFcif1JRLHRbu"},"components":[{"type":"textnode","content":"Regresar al listado principal"}]}]}]}]}],"doctype":"<!DOCTYPE html>","head":{"type":"head","name":"Head Metadata","components":[{"tagName":"meta","name":"Meta Charset","void":true,"attributes":{"charset":"utf-8"}},{"tagName":"meta","name":"Meta Viewport","void":true,"attributes":{"name":"viewport","content":"width=device-width, initial-scale=1"}},{"tagName":"title","type":"text","name":"Page Title","components":[{"type":"textnode","content":"Biografía Nikola Tesla"}]},{"tagName":"link","name":"Google Font Inter","void":true,"attributes":{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap","rel":"stylesheet"}},{"tagName":"link","name":"Google Font Poppins","void":true,"attributes":{"href":"https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&display=swap","rel":"stylesheet"}}]},"docEl":{"tagName":"html","attributes":{"lang":"es"}}},"id":"4B3EmlllkU4VgF15","minHeight":"500px"}],"id":"rpJatXN0BauxIHtosNw4Jhb"},{"name":"Carl Sagan","frames":[{"component":{"type":"wrapper","classes":["gjs-t-body"],"attributes":{"id":"il8i03"},"components":[{"tagName":"header","classes":["header-bar"],"components":[{"classes":["container","header-content"],"components":[{"type":"link","editable":false,"classes":["header-back"],"attributes":{"href":"./index.html"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-arrow-left.svg?color=%2394a3b8","width":"20","height":"20","alt":"Back"}},{"tagName":"span","type":"text","components":[{"type":"textnode","content":"Volver al listado"}]}]},{"tagName":"span","type":"text","classes":["header-logo"],"components":[{"type":"textnode","content":"Científicos • Biografías"}]}]}]},{"tagName":"main","classes":["container"],"components":[{"type":"comment","content":" HERO SECTION "},{"tagName":"section","classes":["hero-section"],"attributes":{"id":"ivuwgdo"},"components":[{"classes":["hero-header"],"attributes":{"id":"i3txba4"}},{"classes":["hero-grid"],"components":[{"type":"comment","content":" Columna Izquierda: Imagen Grande "},{"classes":["col-left"],"components":[{"classes":["hero-image-wrapper"],"attributes":{"id":"is7dbdz"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["hero-image"],"attributes":{"src":"https://upload.wikimedia.org/wikipedia/commons/b/be/Carl_Sagan_Planetary_Society.JPG","alt":"Carl Sagan","id":"ijuso0h"}},{"type":"heading","classes":["hero-title","font-serif"],"attributes":{"id":"iynudbh"},"components":[{"type":"textnode","content":"Carl Sagan"}]},{"tagName":"p","type":"text","classes":["hero-subtitle"],"attributes":{"id":"ir5r0dh"},"components":[{"type":"textnode","content":"Astrónomo, astrofísico y el mayor divulgador del siglo XX"}]}]}]},{"type":"comment","content":" Columna Derecha: Detalles "},{"classes":["col-right"],"components":[{"type":"comment","content":" Tarjeta Violeta de Aporte "},{"classes":["highlight-box"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["highlight-icon"],"attributes":{"src":"https://api.iconify.design/lucide-sparkles.svg?color=%23a78bfa","alt":"Star"}},{"tagName":"h2","type":"heading","classes":["font-serif"],"attributes":{"id":"i1l9yds"},"components":[{"type":"textnode","content":"La Voz del Cosmos"}]},{"tagName":"p","type":"text","attributes":{"id":"itfxp6a"},"components":[{"type":"textnode","content":"\n              Transformó la ciencia en poesía. A través de la serie \"Cosmos\", conectó la historia del universo con la experiencia humana, inspirando a millones a mirar las estrellas.\n            "}]},{"classes":["stats-row"],"components":[{"classes":["stat"],"components":[{"type":"text","classes":["stat-label"],"components":[{"type":"textnode","content":"Organización"}]},{"type":"text","classes":["stat-val"],"components":[{"type":"textnode","content":"Planetary Society"}]}]},{"classes":["stat"],"components":[{"type":"text","classes":["stat-label"],"components":[{"type":"textnode","content":"Misión Clave"}]},{"type":"text","classes":["stat-val"],"components":[{"type":"textnode","content":"Voyager"}]}]}]}]},{"type":"comment","content":" Tarjeta Datos "},{"classes":["card","card-padding"],"components":[{"tagName":"h3","type":"heading","classes":["font-serif"],"attributes":{"id":"iw1ramr"},"components":[{"type":"textnode","content":"Datos Rápidos"}]},{"classes":["quick-list"],"components":[{"classes":["quick-item"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["quick-icon"],"attributes":{"src":"https://api.iconify.design/lucide-graduation-cap.svg?color=%2394a3b8","alt":"Edu"}},{"tagName":"span","type":"text","classes":["quick-text"],"components":[{"type":"textnode","content":"Profesor en la Universidad de Cornell (David Duncan Professor)."}]}]},{"classes":["quick-item"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["quick-icon"],"attributes":{"src":"https://api.iconify.design/lucide-disc.svg?color=%2394a3b8","alt":"Disc"}},{"tagName":"span","type":"text","classes":["quick-text"],"components":[{"type":"textnode","content":"Diseñó el \"Disco de Oro\" de las Voyager."}]}]},{"classes":["quick-item"],"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["quick-icon"],"attributes":{"src":"https://api.iconify.design/lucide-book-open.svg?color=%2394a3b8","alt":"Book"}},{"tagName":"span","type":"text","classes":["quick-text"],"components":[{"type":"textnode","content":"Autor ganador del Premio Pulitzer (\"Los dragones del Edén\")."}]}]}]}]}]}]}]},{"type":"comment","content":" BIO SECTION "},{"tagName":"section","classes":["bio-section"],"attributes":{"id":"bio"},"components":[{"classes":["bio-grid"],"components":[{"type":"comment","content":" Texto Principal "},{"classes":["bio-main"],"components":[{"tagName":"h2","type":"heading","classes":["font-serif"],"attributes":{"id":"i2kj8xk"},"components":[{"type":"textnode","content":"Un Viaje Personal"}]},{"classes":["bio-text"],"components":[{"tagName":"p","type":"text","components":[{"type":"textnode","content":"\n              Carl Edward Sagan (1934–1996) fue mucho más que un científico; fue el embajador de la Tierra ante el universo. Nacido en Brooklyn, dedicó su vida a responder una pregunta fundamental: ¿Estamos solos?\n            "}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"\n              Como astrofísico, sus contribuciones fueron vitales: predijo las altas temperaturas de Venus debido al efecto invernadero y teorizó sobre los océanos subterráneos en las lunas de Júpiter. Sin embargo, su verdadero superpoder fue la comunicación.\n            "}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"\n              En 1980, estrenó \"Cosmos: Un viaje personal\", una serie que se convirtió en el programa más visto en la historia de la televisión pública estadounidense. Con su famosa frase \"billions and billions\" (miles de millones), nos enseñó nuestra verdadera escala en el universo.\n            "}]}]},{"classes":["mini-grid"],"components":[{"classes":["card","card-padding"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-flame.svg?color=%23a78bfa","width":"32","alt":"Icon","id":"i49tlxm"}},{"tagName":"h4","type":"heading","attributes":{"id":"ihrydqg"},"components":[{"type":"textnode","content":"El Invierno Nuclear"}]},{"tagName":"p","type":"text","attributes":{"id":"iaklawi"},"components":[{"type":"textnode","content":"\n                Advirtió al mundo sobre las consecuencias climáticas catastróficas de una guerra nuclear, influyendo en la política global.\n              "}]}]},{"classes":["card","card-padding"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-search.svg?color=%23a78bfa","width":"32","alt":"Icon","id":"igqidsf"}},{"tagName":"h4","type":"heading","attributes":{"id":"iaeakcu"},"components":[{"type":"textnode","content":"SETI"}]},{"tagName":"p","type":"text","attributes":{"id":"ijr7e01"},"components":[{"type":"textnode","content":"\n                Fue un pionero en la búsqueda de inteligencia extraterrestre, abogando por el uso de radiotelescopios para escuchar el cosmos.\n              "}]}]}]}]},{"type":"comment","content":" Timeline Lateral "},{"classes":["bio-sidebar"],"components":[{"classes":["card","card-padding"],"components":[{"tagName":"h3","type":"heading","classes":["font-serif"],"attributes":{"id":"izc8lth"},"components":[{"type":"textnode","content":"Cronología"}]},{"classes":["timeline"],"components":[{"classes":["timeline-item"],"components":[{"classes":["timeline-dot"]},{"type":"text","classes":["timeline-year"],"components":[{"type":"textnode","content":"1934"}]},{"type":"text","classes":["timeline-desc"],"components":[{"type":"textnode","content":"Nace en Nueva York."}]}]},{"classes":["timeline-item"],"components":[{"classes":["timeline-dot"]},{"type":"text","classes":["timeline-year"],"components":[{"type":"textnode","content":"1960"}]},{"type":"text","classes":["timeline-desc"],"components":[{"type":"textnode","content":"Doctorado en la Universidad de Chicago."}]}]},{"classes":["timeline-item"],"components":[{"classes":["timeline-dot"]},{"type":"text","classes":["timeline-year"],"components":[{"type":"textnode","content":"1977"}]},{"type":"text","classes":["timeline-desc"],"components":[{"type":"textnode","content":"Lanzamiento de las sondas Voyager con su Disco de Oro."}]}]},{"classes":["timeline-item"],"components":[{"classes":["timeline-dot"]},{"type":"text","classes":["timeline-year"],"components":[{"type":"textnode","content":"1980"}]},{"type":"text","classes":["timeline-desc"],"components":[{"type":"textnode","content":"Estreno mundial de \"Cosmos\"."}]}]},{"classes":["timeline-item"],"components":[{"classes":["timeline-dot"]},{"type":"text","classes":["timeline-year"],"components":[{"type":"textnode","content":"1996"}]},{"type":"text","classes":["timeline-desc"],"components":[{"type":"textnode","content":"Fallece en Seattle, dejando un legado eterno."}]}]}]}]}]}]}]},{"type":"comment","content":" WORKS SECTION "},{"tagName":"section","classes":["works-section"],"components":[{"classes":["works-header"],"components":[{"tagName":"h2","type":"heading","classes":["works-title","font-serif"],"components":[{"type":"textnode","content":"Legado Bibliográfico"}]},{"tagName":"span","type":"text","attributes":{"id":"imhefwz"},"components":[{"type":"textnode","content":"Obras esenciales"}]}]},{"classes":["works-grid"],"components":[{"type":"comment","content":" Work 1 "},{"classes":["work-item"],"components":[{"classes":["work-icon-box"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://api.iconify.design/lucide-book.svg?color=%23a78bfa","width":"24","alt":"Book"}}]},{"tagName":"h3","type":"heading","attributes":{"id":"ikze2qo"},"components":[{"type":"textnode","content":"Cosmos"}]},{"tagName":"p","type":"text","attributes":{"id":"iudjh5m"},"components":[{"type":"textnode","content":"\n            El libro de ciencia más vendido en inglés. Una narrativa épica sobre la evolución del universo y la civilización.\n          "}]}]},{"type":"comment","content":" Work 2 "},{"classes":["work-item"],"components":[{"classes":["work-icon-box"],"components":[{"type":"image","resizable